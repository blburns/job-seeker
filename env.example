# =============================================================================
# Example environment file - copy to .env and customize
# cp env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Flask
# -----------------------------------------------------------------------------
FLASK_ENV=development
FLASK_DEBUG=True

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=Job Seeker
APP_VERSION=1.0.0
COMPANY_NAME=Job Seeker
APP_URL=http://localhost:5000

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
SECRET_KEY=your-super-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# =============================================================================
# OAUTH CONFIGURATION
# =============================================================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# -----------------------------------------------------------------------------
# Database (choose one)
# -----------------------------------------------------------------------------
# PostgreSQL:
# DB_TYPE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=boilerplate_db
# DB_USER=boilerplate_user
# DB_PASSWORD=your_password
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
# POSTGRES_SUPERUSER=postgres
# POSTGRES_SUPERUSER_PASSWORD=postgres_password

# SQLite (development):
DB_TYPE=sqlite
DB_NAME=app.db

# -----------------------------------------------------------------------------
# Redis & Celery (optional - for task queue and admin monitoring)
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Cache (optional)
# -----------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379/0
# CACHE_TYPE=redis
CACHE_TYPE=simple

# -----------------------------------------------------------------------------
# Email (optional)
# -----------------------------------------------------------------------------
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_DEFAULT_SENDER=noreply@yourapp.com

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# LOG_LEVEL=INFO
# LOG_FILE=logs/app.log

# -----------------------------------------------------------------------------
# Error tracking (optional - Phase 1.5)
# -----------------------------------------------------------------------------
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ENVIRONMENT=production
