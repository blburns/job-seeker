# =============================================================================
# Example environment file - copy to .env and customize
# cp env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Flask
# -----------------------------------------------------------------------------
FLASK_ENV=development
FLASK_DEBUG=True

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=Job Seeker
APP_VERSION=1.0.0
COMPANY_NAME=Job Seeker
APP_URL=http://localhost:5000

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
SECRET_KEY=your-super-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# =============================================================================
# OAUTH CONFIGURATION
# =============================================================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# -----------------------------------------------------------------------------
# Database (choose one)
# -----------------------------------------------------------------------------
# PostgreSQL:
# DB_TYPE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=boilerplate_db
# DB_USER=boilerplate_user
# DB_PASSWORD=your_password
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
# POSTGRES_SUPERUSER=postgres
# POSTGRES_SUPERUSER_PASSWORD=postgres_password

# SQLite (development):
DB_TYPE=sqlite
DB_NAME=app.db

# -----------------------------------------------------------------------------
# Redis & Celery (optional — only if you run celery worker + beat separately)
# Local dev with `python run.py` does NOT need Redis or Docker.
# -----------------------------------------------------------------------------
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Cache (optional)
# -----------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379/0
# CACHE_TYPE=redis
CACHE_TYPE=simple

# -----------------------------------------------------------------------------
# Email (optional)
# -----------------------------------------------------------------------------
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_DEFAULT_SENDER=noreply@yourapp.com

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# LOG_LEVEL=INFO
# LOG_FILE=logs/app.log

# -----------------------------------------------------------------------------
# Job seeker automation (discovery, LLM tailoring, auto-apply)
# -----------------------------------------------------------------------------
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
DISCOVERY_RATE_LIMIT_PER_HOUR=100
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Google AI Studio (Gemini) — get a key at https://aistudio.google.com/apikey
# Either GEMINI_API_KEY or GOOGLE_API_KEY works. When set, Gemini is preferred over OpenAI unless LLM_PROVIDER=openai.
GEMINI_API_KEY=
GOOGLE_API_KEY=
# Current default; retired names (gemini-1.5-flash, gemini-2.0-flash) are auto-mapped.
GEMINI_MODEL=gemini-3.5-flash
# Optional force: openai | gemini | auto (default)
LLM_PROVIDER=auto
# Cover letter regenerate: keep retrying on free-tier rate limits until success
# COVER_LETTER_RETRY_MAX=0 means unlimited attempts (until timeout)
COVER_LETTER_RETRY_MAX=0
COVER_LETTER_RETRY_BASE_SECONDS=30
COVER_LETTER_RETRY_TIMEOUT_SECONDS=1800
# Reserved — not implemented yet
ANTHROPIC_API_KEY=
# Fernet key for encrypting portal session JSON at rest (required for LinkedIn/Indeed credentials)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=
APPLY_AUTOMATION_ENABLED=false
# Emergency kill switch — blocks all automated batch submits
# Env requires restart. Prefer Admin → Settings file toggle (no restart): instance/automation_disabled.flag
AUTOMATION_DISABLED=false
PLAYWRIGHT_HEADLESS=true
# Local session export: use installed Google Chrome (fixes DNS issues on some Macs)
PLAYWRIGHT_CHANNEL=chrome
DAILY_APPLY_CAP=25
LINKEDIN_AUTO_APPLY_ENABLED=false
INDEED_AUTO_APPLY_ENABLED=false
LINKEDIN_SCRAPE_ENABLED=false
INDEED_SCRAPE_ENABLED=false
# MyGreenhouse aggregated search (boards list entry "my") — uses greenhouse portal credentials
GREENHOUSE_MY_SEARCH_ENABLED=true
# Indeed blocks headless browsers — headed Chrome is used automatically for Indeed scrapes
INDEED_PLAYWRIGHT_HEADLESS=false
SCRAPE_RATE_LIMIT_PER_HOUR=20
SCRAPE_DELAY_MIN_MS=2000
SCRAPE_DELAY_MAX_MS=6000
# false = in-memory rate limits (default for local dev, no Redis required)
# true  = always use Redis (Docker / celery worker setups)
# auto  = use Redis only when CELERY_BROKER_URL is set
SCRAPE_USE_REDIS=false

# -----------------------------------------------------------------------------
# Error tracking (optional - Phase 1.5)
# -----------------------------------------------------------------------------
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ENVIRONMENT=production
